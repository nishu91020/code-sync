    "packages/*"
  ],
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@monaco-editor/react": "^4.7.0",
    "@mui/material": "^9.2.0",
    "@prisma/client": "^7.8.0",
    "monaco-editor": "^0.55.1",
    "prism": "^4.1.2",
    "react-router-dom": "^7.18.1",
    "y-monaco": "^0.1.6",
    "yjs": "^13.6.31"
  }
